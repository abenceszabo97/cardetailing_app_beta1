{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "server:app", "--reload", "--port", "8001"],
      "port": 8001,
      "cwd": "backend"
    },
    {
      "name": "Frontend Admin",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3000,
      "cwd": "frontend-admin",
      "env": { "PORT": "3000" }
    },
    {
      "name": "Frontend Booking",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3001,
      "cwd": "frontend-booking",
      "env": { "PORT": "3001" }
    }
  ]
}
